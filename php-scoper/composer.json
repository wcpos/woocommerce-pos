{
  "require-dev": {
    "humbug/php-scoper": "0.16.2"
  },
  "require": {
    "php": ">=7.4",
    "ext-json": "*",
    "chillerlan/php-qrcode": "^5.0",
    "dompdf/dompdf": "^3.1",
    "firebase/php-jwt": "^6.10.0",
    "phpfastcache/phpfastcache": "^8.1.4",
    "picqer/php-barcode-generator": "^2.4"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "platform": {
      "php": "7.4"
    },
    "preferred-install": "dist",
    "sort-packages": true,
    "audit": {
      "ignore": {
        "PKSA-y2cr-5h3j-g3ys": "Temporary ignore: php-jwt >=6.10.1 requires PHP >=8.0 while plugin minimum remains PHP 7.4."
      }
    }
  }
}
