<receipt paper-width="48">
  <!-- width="*" is deliberate: flexible columns absorb remaining CPL so this
       80mm template can render cleanly on both 42- and 48-CPL printers. -->
  <align mode="center">
    <bold><size width="2" height="2">{{store.name}}</size></bold>
    <text>{{store.address_lines.0}}</text>
    <text>{{store.phone}}</text>
  </align>
  <line />
  <row>
    <col width="12">{{order.number}}</col>
    <col width="*" align="right">{{order.created.datetime}}</col>
  </row>
  <line />
  {{#lines}}
  <bold>{{name}}</bold>
  {{#discounts}}
  <row>
    <col width="*">x{{qty}} @ {{unit_subtotal_incl_display}}</col>
    <col width="12" align="right">-{{discounts_incl_display}}</col>
  </row>
  {{/discounts}}
  <row>
    <col width="5">x{{qty}}</col>
    <col width="*">@ {{unit_price_incl_display}}</col>
    <col width="12" align="right">{{line_total_incl_display}}</col>
  </row>
  {{/lines}}
  <line />
  <row>
    <col width="*">{{i18n.subtotal}}</col>
    <col width="14" align="right">{{totals.subtotal_incl_display}}</col>
  </row>
  {{#shipping}}
  <row>
    <col width="*">{{label}}</col>
    <col width="14" align="right">{{total_incl_display}}</col>
  </row>
  {{/shipping}}
  {{#fees}}
  <row>
    <col width="*">{{label}}</col>
    <col width="14" align="right">{{total_incl_display}}</col>
  </row>
  {{/fees}}
  {{#discounts}}
  <row>
    <col width="*">{{label}}</col>
    <col width="14" align="right">-{{total_incl_display}}</col>
  </row>
  {{/discounts}}
  {{#tax_summary}}
  <row>
    <col width="*">{{label}}{{#rate}} ({{rate}}%){{/rate}}</col>
    <col width="14" align="right">{{tax_amount_display}}</col>
  </row>
  {{/tax_summary}}
  <line style="double" />
  <row>
    <col width="*"><bold>{{i18n.total}}</bold></col>
    <col width="14" align="right"><bold>{{totals.total_incl_display}}</bold></col>
  </row>
  <line />
  {{#payments}}
  <row>
    <col width="*">{{method_title}}</col>
    <col width="14" align="right">{{amount_display}}</col>
  </row>
  {{#tendered}}
  <row>
    <col width="*">  {{i18n.tendered}}</col>
    <col width="14" align="right">{{tendered_display}}</col>
  </row>
  {{/tendered}}
  {{#change}}
  <row>
    <col width="*">  {{i18n.change}}</col>
    <col width="14" align="right">{{change_display}}</col>
  </row>
  {{/change}}
  {{/payments}}
  <feed lines="2" />
  <align mode="center">
    <barcode type="code128" height="60">{{order.number}}</barcode>
  </align>
  <feed lines="1" />
  <align mode="center">
    <text>{{i18n.thank_you}}</text>
  </align>
  <cut />
</receipt>
