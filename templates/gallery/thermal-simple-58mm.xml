<receipt paper-width="32">
  <align mode="center">
    <bold><size width="2" height="2">{{store.name}}</size></bold>
    <text>{{store.address_lines.0}}</text>
    <text>{{store.phone}}</text>
  </align>
  <line />
  <text>{{order.number}}</text>
  <text>{{order.created.datetime}}</text>
  <line />
  {{#lines}}
  <bold>{{name}}</bold>
  {{#discounts}}
  <row>
    <col width="16">x{{qty}} @ {{unit_subtotal_incl_display}}</col>
    <col width="16" align="right">-{{discounts_incl_display}}</col>
  </row>
  {{/discounts}}
  <row>
    <col width="6">x{{qty}}</col>
    <col width="10">@ {{unit_price_incl_display}}</col>
    <col width="16" align="right">{{line_total_incl_display}}</col>
  </row>
  {{/lines}}
  <line />
  <row>
    <col width="16">{{i18n.subtotal}}</col>
    <col width="16" align="right">{{totals.subtotal_incl_display}}</col>
  </row>
  {{#shipping}}
  <row>
    <col width="16">{{label}}</col>
    <col width="16" align="right">{{total_incl_display}}</col>
  </row>
  {{/shipping}}
  {{#fees}}
  <row>
    <col width="16">{{label}}</col>
    <col width="16" align="right">{{total_incl_display}}</col>
  </row>
  {{/fees}}
  {{#discounts}}
  <row>
    <col width="16">{{label}}</col>
    <col width="16" align="right">-{{total_incl_display}}</col>
  </row>
  {{/discounts}}
  {{#tax_summary}}
  <row>
    <col width="16">{{label}}{{#rate}} ({{rate}}%){{/rate}}</col>
    <col width="16" align="right">{{tax_amount_display}}</col>
  </row>
  {{/tax_summary}}
  <line style="double" />
  <row>
    <col width="16"><bold>{{i18n.total}}</bold></col>
    <col width="16" align="right"><bold>{{totals.total_incl_display}}</bold></col>
  </row>
  <line />
  {{#payments}}
  <row>
    <col width="16">{{method_title}}</col>
    <col width="16" align="right">{{amount_display}}</col>
  </row>
  {{#tendered}}
  <row>
    <col width="16">  {{i18n.tendered}}</col>
    <col width="16" align="right">{{tendered_display}}</col>
  </row>
  {{/tendered}}
  {{#change}}
  <row>
    <col width="16">  {{i18n.change}}</col>
    <col width="16" align="right">{{change_display}}</col>
  </row>
  {{/change}}
  {{/payments}}
  <feed lines="2" />
  <align mode="center">
    <text>{{i18n.thank_you}}</text>
  </align>
  <cut />
</receipt>
