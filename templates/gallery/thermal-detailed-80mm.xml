<receipt paper-width="48">
  <align mode="center">
    <bold><size width="2" height="2">{{store.name}}</size></bold>
    <text>{{store.address_lines.0}}</text>
    <text>{{store.address_lines.1}}</text>
    <text>{{store.phone}}</text>
  </align>
  <line />
  <row>
    <col width="16">{{i18n.order}}:</col>
    <col width="32" align="right">{{meta.order_number}}</col>
  </row>
  <row>
    <col width="16">{{i18n.date}}:</col>
    <col width="32" align="right">{{#meta.created_at_local}}{{meta.created_at_local}}{{/meta.created_at_local}}{{^meta.created_at_local}}{{meta.created_at_gmt}}{{/meta.created_at_local}}</col>
  </row>
  {{#cashier.name}}
  <row>
    <col width="16">{{i18n.cashier}}:</col>
    <col width="32" align="right">{{cashier.name}}</col>
  </row>
  {{/cashier.name}}
  <line />
  {{#customer.name}}
  <bold><text>{{i18n.customer}}</text></bold>
  <text>{{customer.name}}</text>
  {{#customer.billing_address.email}}
  <text>{{customer.billing_address.email}}</text>
  {{/customer.billing_address.email}}
  <line />
  {{/customer.name}}
  <row>
    <col width="24"><bold>{{i18n.item}}</bold></col>
    <col width="8" align="right"><bold>{{i18n.qty}}</bold></col>
    <col width="16" align="right"><bold>{{i18n.total}}</bold></col>
  </row>
  <line />
  {{#lines}}
  <text>{{name}}</text>
  {{#sku}}
  <text>SKU: {{sku}}</text>
  {{/sku}}
  {{#discounts}}
  <row>
    <col width="24">@ {{unit_subtotal_incl}}</col>
    <col width="24" align="right">-{{discounts_incl}}</col>
  </row>
  {{/discounts}}
  <row>
    <col width="24">@ {{unit_price_incl}}</col>
    <col width="8" align="right">{{qty}}</col>
    <col width="16" align="right">{{line_total_incl}}</col>
  </row>
  {{/lines}}
  {{#meta.customer_note}}
  <line />
  <bold><text>{{i18n.customer_note}}</text></bold>
  <text>{{meta.customer_note}}</text>
  {{/meta.customer_note}}
  <line />
  <row>
    <col width="24">{{i18n.subtotal}}</col>
    <col width="24" align="right">{{totals.subtotal_incl}}</col>
  </row>
  {{#discounts}}
  <row>
    <col width="24">{{label}}</col>
    <col width="24" align="right">-{{total_incl}}</col>
  </row>
  {{/discounts}}
  {{#shipping}}
  <row>
    <col width="24">{{label}}</col>
    <col width="24" align="right">{{total_incl}}</col>
  </row>
  {{/shipping}}
  {{#fees}}
  <row>
    <col width="24">{{label}}</col>
    <col width="24" align="right">{{total_incl}}</col>
  </row>
  {{/fees}}
  <line />
  {{#tax_summary}}
  <row>
    <col width="24">{{label}}{{#rate}} ({{rate}}%){{/rate}}</col>
    <col width="24" align="right">{{tax_amount}}</col>
  </row>
  {{/tax_summary}}
  <line style="double" />
  <row>
    <col width="24"><bold><size width="2">{{i18n.total}}</size></bold></col>
    <col width="24" align="right"><bold><size width="2">{{totals.grand_total_incl}}</size></bold></col>
  </row>
  <line style="double" />
  {{#payments}}
  <row>
    <col width="24">{{method_title}}</col>
    <col width="24" align="right">{{amount}}</col>
  </row>
  {{#tendered}}
  <row>
    <col width="24">  {{i18n.tendered}}</col>
    <col width="24" align="right">{{tendered}}</col>
  </row>
  {{/tendered}}
  {{#change}}
  <row>
    <col width="24">  {{i18n.change}}</col>
    <col width="24" align="right">{{change}}</col>
  </row>
  {{/change}}
  {{#reference}}
  <text>  Ref: {{reference}}</text>
  {{/reference}}
  {{/payments}}
  <feed lines="2" />
  <align mode="center">
    <barcode type="code128" height="60">{{meta.order_number}}</barcode>
  </align>
  <feed lines="1" />
  <align mode="center">
    <text>{{i18n.thank_you_purchase}}</text>
  </align>
  <cut />
</receipt>
